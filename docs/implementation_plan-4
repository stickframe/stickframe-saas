-- 6. Views de Benchmarks
CREATE OR REPLACE VIEW public.vw_benchmark_m2 AS
  SELECT 
    tipologia,
    cidade_publica as cidade,
    uf_publica as uf,
    count(id) as total_obras,
    round(avg(contrato / area_m2), 2) as custo_medio_m2
  FROM public.obras
  WHERE publicada = true AND area_m2 > 0 AND contrato > 0
  GROUP BY tipologia, cidade_publica, uf_publica
  HAVING count(id) >= 10; -- Anonimização mínima
```

